{
  "name": "rune-devtools",
  "version": "1.0.2",
  "description": "Browser devtools overlay for the Rune framework",
  "repository": {
    "type": "git",
    "url": "https://github.com/oats7777/rune-devtools",
    "directory": "packages/devtools"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "rune-ts": ">=0.9.8"
  },
  "devDependencies": {
    "rune-ts": "^0.9.8",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@fxts/core": "^1.4.0"
  }
}
